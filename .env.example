NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Vercel Cron auth (must match Authorization: Bearer header)
CRON_SECRET=poolpay_secure_cron_trigger_2026

# LLM router keys (comma-separated for rotation)
GROQ_KEYS=gsk_key_one,gsk_key_two
CEREBRAS_KEYS=csk_key_one
GEMINI_KEYS=AIza_key_one,AIza_key_two

# Future Serper discovery
SERPER_KEYS=serper_key_one,serper_key_two

# Google Maps — Places Autocomplete + Embed (hotel destination)
# Enable: Places API, Places API (New), Maps Embed API
GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# Travelpayouts affiliate marker (MakeMyTrip, Cleartrip, Booking.com, Agoda deep links)
# Get from https://www.travelpayouts.com — without this, OTA links still work (no commission)
NEXT_PUBLIC_TRAVELPAYOUTS_MARKER=your_travelpayouts_marker_id

# Optional scrape target override
CARD_SCRAPE_URL=https://www.livemint.com/topic/credit-cards
